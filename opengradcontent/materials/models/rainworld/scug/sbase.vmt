VertexLitGeneric
{
	$basetexture "models/rainworld/scug/Sbase_diff"
	$surfaceprop Flesh

	$bumpmap "models/rainworld/scug/Normal"

	$phong 1
	$phongexponent 1
	$phongboost	0.2
	$phongfresnelranges	"[0.05 0.5 1]"
	$phongalbedotint "1"

	Proxies
	{
		PlayerColor
		{
			resultVar		$color2 // pass the player color value to Gmod
			default		0.23 0.35 0.41 // unused for now.
		}
		Clamp
		{
			min 0
			max 1
			srcVar1 "$color2"
			resultVar "$color2"
		}
	}

}
