VertexLitGeneric
{
	$basetexture "models/betametrocat/catcop"
	$bumpmap "models/betametrocat/catcop_n"
	
	$envmap "env_cubemap"
	$normalmapalphaenvmapmask 1
	$envmaptint "[0.11 0.11 0.11]"
	$envmapcontrast 0.44
	$envmapfresnel 1

	$phong 1
	$phongfresnelranges "[0.1 0.55 1]"
	$phongtint "[0.75 0.75 0.80]"
	$phongboost 1.2
	$phongexponent 5
	
}